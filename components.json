{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "default",
  "rsc": false,
  "tsx": false,
  "tailwind": {
    "config": "tailwind.config.js",
    "css": "src/styles/globals.css",
    "baseColor": "slate",
    "cssVariables": true,
    "prefix": ""
  },
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/shared/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "iconLibrary": "lucide",
  "registries": {
    "@cult-ui": "https://www.cult-ui.com/r/{name}.json"
  },
  "_notes": {
    "cult-ui-cli": "Usar shadcn@beta para instalar componentes Cult UI: npx shadcn@beta add @cult-ui/<name>",
    "cult-ui-search": "npx shadcn@beta search '@cult-ui' — 157 componentes disponibles",
    "cult-ui-docs": "https://www.cult-ui.com/docs"
  }
}
